# 上海交大体育预约系统 - 环境变量配置
# 复制此文件为 .env 并填入真实配置

# Supabase 配置 (前端使用，需以 VITE_ 开头)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 账号配置 (爬虫使用)
SJTU_USERNAME=your-username
SJTU_PASSWORD=your-password

# 和风天气配置 (前端使用，需以 VITE_ 开头)
VITE_QWEATHER_API_KEY=your-qweather-api-key
VITE_QWEATHER_API_HOST=your-qweather-api-host
VITE_QWEATHER_LOCATION=101021200
